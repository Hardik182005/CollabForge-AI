# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080
FRONTEND_ORIGINS=http://localhost:3000
PUBLIC_APP_URL=

# ── Anakin (required for research features) ─────────────────────────
ANAKIN_API_KEY=
ANAKIN_API_BASE_URL=https://api.anakin.io
ANAKIN_JOB_TIMEOUT_SECONDS=120
ANAKIN_CACHE_TTL_SECONDS=3600
ANAKIN_MAX_CREDITS_PER_REQUEST=25

# ── LLM / generation (OpenAI required for research reasoning) ───────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: Groq powers the help chatbot; Gemini is an LLM fallback
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Voice (optional — disables Voice Studio when missing) ───────────
ELEVENLABS_API_KEY=

# ── Optional data providers ─────────────────────────────────────────
YOUTUBE_API_KEY=
NEWS_API_KEY=

# ── AWS (production) ─────────────────────────────────────────────────
AWS_REGION=
AWS_S3_BUCKET=
AWS_DYNAMODB_TABLE=
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# ── Persistence ──────────────────────────────────────────────────────
# local = JSON files under LOCAL_STORAGE_PATH; dynamodb = AWS DynamoDB
DATABASE_MODE=local
LOCAL_STORAGE_PATH=./data/local
