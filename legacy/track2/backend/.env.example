# LLM Providers
# Get Gemini key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Get Groq key from https://console.groq.com/
GROQ_API_KEY=gsk_...

# Get OpenAI key from https://platform.openai.com/
OPENAI_API_KEY=sk-...

# Voice & Video API keys
ELEVENLABS_API_KEY=...
RUNWAY_API_KEY=...

# Vector Database (Pinecone)
# Get Pinecone key from https://app.pinecone.io/
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws

# Data Scraper Sources (API Credentials)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
YOUTUBE_API_KEY=...
NEWS_API_KEY=...

# App Config
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
PORT=8001
